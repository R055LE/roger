# Roger — environment template. Copy to roger.env, fill in, then encrypt in place:
#   cp roger.env.example roger.env && sops -e -i roger.env
# The real roger.env (even encrypted) is git-ignored and NEVER committed.
#
# Parsed as dotenv (by `sops exec-env`), so do NOT put an inline "# comment" after a value —
# the parser keeps it as part of the value. Keep comments on their own lines, like these.

# --- required ---
# bot token. Do NOT enable Message Content / Members / Presence intents.
DISCORD_TOKEN=
# OpenRouter key — ideally dedicated, with a key-level spend limit
OPENROUTER_API_KEY=
# your Discord user ID (int)
OWNER_ID=
# the one guild this bot serves (int)
GUILD_ID=

# --- llm (comma-separated priority list; primary first, the rest are OpenRouter fallbacks) ---
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# every MODEL_ADMIN entry MUST support tool calling (verify with the OpenRouter "Tools" filter)
MODEL_ADMIN=anthropic/claude-haiku-4.5,openai/gpt-5-mini,google/gemini-2.5-flash
MODEL_AMBIENT=google/gemini-2.5-flash-lite,openai/gpt-5-nano,mistralai/mistral-nemo
MODEL_DIGEST=google/gemini-2.5-flash-lite,openai/gpt-4.1-nano,deepseek/deepseek-v3.2

# --- budgets (daily in+out tokens per brain) ---
DAILY_TOKENS_ADMIN=150000
DAILY_TOKENS_AMBIENT=40000
DAILY_TOKENS_DIGEST=30000

# --- ambient rate limiting ---
AMBIENT_RATE_PER_USER=5
AMBIENT_RATE_WINDOW_S=600
AMBIENT_GLOBAL_HOURLY=30

# --- digest ---
# comma-separated RSS/Atom URLs
DIGEST_FEEDS=
# target channel ID (int)
DIGEST_CHANNEL_ID=
# local hour 0-23
DIGEST_HOUR=8
TZ=America/Detroit

# --- runtime ---
DB_PATH=/data/roger.db
LOG_LEVEL=INFO
