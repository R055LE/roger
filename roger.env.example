# Roger — environment template. Copy to roger.env, fill in, then encrypt in place:
#   cp roger.env.example roger.env && sops -e -i roger.env
# The real roger.env (even encrypted) is git-ignored and NEVER committed.

# --- required ---
DISCORD_TOKEN=            # bot token. Do NOT enable Message Content / Members / Presence intents.
OPENROUTER_API_KEY=       # OpenRouter key — ideally dedicated, with a key-level spend limit
OWNER_ID=                 # your Discord user ID (int)
GUILD_ID=                 # the one guild this bot serves (int)

# --- llm (comma-separated priority list; primary first, the rest are OpenRouter fallbacks) ---
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
MODEL_ADMIN=              # every entry MUST support tool calling
MODEL_AMBIENT=            # cheapest viable chat model
MODEL_DIGEST=             # cheap summarizer

# --- budgets (daily in+out tokens per brain) ---
DAILY_TOKENS_ADMIN=50000
DAILY_TOKENS_AMBIENT=30000
DAILY_TOKENS_DIGEST=20000

# --- ambient rate limiting ---
AMBIENT_RATE_PER_USER=5
AMBIENT_RATE_WINDOW_S=600
AMBIENT_GLOBAL_HOURLY=30

# --- digest ---
DIGEST_FEEDS=             # comma-separated RSS/Atom URLs
DIGEST_CHANNEL_ID=        # target channel ID (int)
DIGEST_HOUR=8             # local hour 0-23
TZ=America/Detroit

# --- runtime ---
DB_PATH=/data/roger.db
LOG_LEVEL=INFO
