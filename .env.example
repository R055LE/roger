# Copy to .env and fill in. .env is gitignored — never commit real secrets.

# Discord bot token: Developer Portal -> your app -> Bot -> Reset Token. Required.
# Also enable the Message Content privileged intent on the same page.
DISCORD_TOKEN=

# OpenRouter API key: https://openrouter.ai/keys . Required.
OPENROUTER_API_KEY=

# OpenRouter's OpenAI-compatible endpoint. Override only if you proxy it.
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Model slug to route to (e.g. "anthropic/claude-3.5-sonnet"). Set per the spec.
OPENROUTER_MODEL=
